APP_PORT=8080
APP_ENV=development

# PostgreSQL — use local Postgres (macOS username), not Docker defaults
# Example: create DB with  psql -U thuyaaung -d postgres -c "CREATE DATABASE user_management;"
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=thuyaaung
DB_PASSWORD=
DB_NAME=user_management
DB_SSLMODE=disable

# MongoDB (activity logs) — run only Mongo via Docker if needed:
#   docker compose up -d mongodb
MONGO_URI=mongodb://localhost:27017
MONGO_DB=user_management_logs

# JWT — token expires after JWT_EXPIRY_HOURS (returned as expires_at on login)
JWT_SECRET=Zv9Vw4I8q0jbek59BdGEWE34rcnI9PvI8Oc0ruHePB_Dq05TYAuzAgGL0C3UCKj3
JWT_EXPIRY_HOURS=24

# API key — required on every /api/v1 request
API_KEY_REQUIRED=true
API_KEY=lU2EO2lxfYYVBcap8imzOkRic6DpBkADSSUxJnWW__4
API_KEY_HEADER=X-UMA-a394985d00e67ddf

# CORS — comma-separated browser origins (empty = block all cross-origin)
# Use exact Origin values: http://localhost:3000 and http://127.0.0.1:3000 are different
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Skip seeders on startup (useful when DB already seeded)
SKIP_SEED=false

# Admin seed credentials (created on first run)
ADMIN_NAME=Admin User
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password123

# Seeded regular users (password: password123 for both)
#   john@example.com  — role: user
#   jane@example.com  — role: user

# Roles & permissions (static — see GET /api/v1/auth/roles)
# admin: users.manage, categories.view, categories.manage,
#        products.view, products.manage, logs.view
# user:  categories.view, products.view

# AI (OpenAI-compatible API — optional)
AI_ENABLED=false
AI_API_KEY=
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-4o-mini

# Swagger UI — protected with HTTP Basic Auth (not the API JWT)
SWAGGER_ENABLED=true
SWAGGER_PATH=/swagger
SWAGGER_USER=swagger
SWAGGER_PASSWORD=QhY4jjocABbhOM_v7pgWfQ
